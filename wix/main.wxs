<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="PrimeNetEngine" Manufacturer="PrimeNetEngine" Version="0.5.0" UpgradeCode="7d396058-80ee-4a51-8320-25103e26841d">
    <MajorUpgrade DowngradeErrorMessage="A newer version of PrimeNetEngine is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="PrimeNetEngine">
        <Component Id="MainBinary" Guid="bb15ba75-0e38-4d2e-9ef2-b85c96dc5b5a">
          <File Source="$(var.CargoTargetDir)\release\prime-net-engine.exe" KeyPath="yes" />
          <Environment Id="AddToPath" Name="PATH" Value="[INSTALLFOLDER]" Permanent="no" Part="last" Action="set" />
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuPrime" Name="PrimeNetEngine">
        <Component Id="StartMenuShortcut" Guid="9511ab84-0c06-46ab-b2d5-27add047c9b9">
          <Shortcut Id="PrimeNetShortcut" Name="Prime Net Engine" Target="[INSTALLFOLDER]prime-net-engine.exe" WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="ProgramMenuPrimeRemove" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\PrimeNetEngine" Name="installed" Type="integer" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="PrimeNetEngine" Level="1">
      <ComponentRef Id="MainBinary" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>
  </Package>
</Wix>
